{
  "viewport": {
    "device": {
      "$type": "string",
      "$value": "normal"
    },
    "frame-width": {
      "$type": "dimension",
      "$value": "1440px"
    },
    "root-font-size": {
      "$type": "number",
      "$value": "{font-size.03}"
    },
    "scale": {
      "$type": "number",
      "$value": 1
    },
    "breakpoints": {
      "width-min": {
        "$type": "number",
        "$value": 871
      },
      "width-max": {
        "$type": "number",
        "$value": 1920
      },
      "height-min": {
        "$type": "number",
        "$value": 600
      },
      "height-max": {
        "$type": "number",
        "$value": 2000
      }
    }
  },
  "layout": {
    "columns": {
      "count": {
        "$type": "number",
        "$value": 12
      },
      "margin": {
        "$type": "dimension",
        "$value": "{space.24}"
      },
      "gutter": {
        "$type": "dimension",
        "$value": "{space.20}"
      }
    },
    "sidebar": {
      "width": {
        "$type": "dimension",
        "$value": "280px"
      },
      "collapsed": {
        "$type": "boolean",
        "$value": false
      }
    }
  },
  "component": {
    "profile-picture": {
      "size-default": {
        "$type": "dimension",
        "$value": "{icon.xl}"
      },
      "size-large": {
        "$type": "dimension",
        "$value": "{icon.2xl}"
      }
    },
    "button": {
      "height-s": {
        "$type": "dimension",
        "$value": "{space.36}"
      },
      "height-m": {
        "$type": "dimension",
        "$value": "{space.44}"
      }
    }
  },
  "typography": {
    "title-page": {
      "font-size": {
        "$type": "dimension",
        "$value": "{title-page.size-base}"
      }
    },
    "subtitle": {
      "font-size": {
        "$type": "dimension",
        "$value": "{subtitle.size-large}"
      }
    },
    "heading": {
      "font-size": {
        "$type": "dimension",
        "$value": "{heading.size-large}"
      }
    },
    "body": {
      "font-size": {
        "$type": "dimension",
        "$value": "{body.size-large}"
      }
    },
    "caption": {
      "font-size": {
        "$type": "dimension",
        "$value": "{caption.size-base}"
      }
    }
  }
}
