{
  "viewport": {
    "device": {
      "$type": "string",
      "$value": "mobile"
    },
    "frame-width": {
      "$type": "dimension",
      "$value": "375px"
    },
    "root-font-size": {
      "$type": "number",
      "$value": "{font-size.03}"
    },
    "scale": {
      "$type": "number",
      "$value": 1.25
    },
    "breakpoints": {
      "width-min": {
        "$type": "number",
        "$value": 320
      },
      "width-max": {
        "$type": "number",
        "$value": 870
      },
      "height-min": {
        "$type": "number",
        "$value": 480
      },
      "height-max": {
        "$type": "number",
        "$value": 2000
      }
    }
  },
  "layout": {
    "columns": {
      "count": {
        "$type": "number",
        "$value": 4
      },
      "margin": {
        "$type": "dimension",
        "$value": "{space.20}"
      },
      "gutter": {
        "$type": "dimension",
        "$value": "{space.16}"
      }
    },
    "sidebar": {
      "width": {
        "$type": "dimension",
        "$value": "240px"
      },
      "collapsed": {
        "$type": "boolean",
        "$value": true
      }
    }
  },
  "component": {
    "profile-picture": {
      "size-default": {
        "$type": "dimension",
        "$value": "{icon.l}"
      },
      "size-large": {
        "$type": "dimension",
        "$value": "{icon.xl}"
      },
      "size-default-2": {
        "$type": "dimension",
        "$value": "{icon.l}"
      }
    },
    "button": {
      "height-s": {
        "$type": "dimension",
        "$value": "{space.36}"
      },
      "height-m": {
        "$type": "dimension",
        "$value": "{space.44}"
      }
    }
  },
  "typography": {
    "title-page": {
      "font-size": {
        "$type": "dimension",
        "$value": "{title-page.size-small}"
      }
    },
    "subtitle": {
      "font-size": {
        "$type": "dimension",
        "$value": "{subtitle.size-small}"
      }
    },
    "heading": {
      "font-size": {
        "$type": "dimension",
        "$value": "{heading.size-small}"
      }
    },
    "body": {
      "font-size": {
        "$type": "dimension",
        "$value": "{body.size-large}"
      }
    },
    "caption": {
      "font-size": {
        "$type": "dimension",
        "$value": "{caption.font-size}"
      }
    }
  }
}
