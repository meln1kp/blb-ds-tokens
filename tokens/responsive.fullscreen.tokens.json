{
  "viewport": {
    "device": {
      "$type": "string",
      "$value": "fullscreen"
    },
    "device-width": {
      "$type": "dimension",
      "$value": "1200px"
    },
    "root-font-size": {
      "$type": "number",
      "$value": "{font-size.03}"
    },
    "scale": {
      "$type": "number",
      "$value": 1
    },
    "breakpoints": {
      "width-min": {
        "$type": "number",
        "$value": 871
      },
      "width-max": {
        "$type": "number",
        "$value": 1920
      },
      "height-min": {
        "$type": "number",
        "$value": 510
      },
      "height-max": {
        "$type": "number",
        "$value": 599
      }
    }
  },
  "layout": {
    "columns": {
      "count": {
        "$type": "number",
        "$value": 12
      }
    },
    "sidebar": {
      "width": {
        "$type": "dimension",
        "$value": "240px"
      },
      "collapsed": {
        "$type": "boolean",
        "$value": false
      }
    }
  }
}
